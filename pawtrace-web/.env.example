# Copy to .env.local — never commit .env.local to git

# Supabase (get from supabase.com → project settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API key (must match API_KEY in pawtrace-backend/.env)
VITE_BACKEND_API_KEY=your-api-key

# Anthropic Vision API (console.anthropic.com)
# Leave blank → mock AI responses (good for testing UI)
VITE_ANTHROPIC_API_KEY=sk-ant-your-key
