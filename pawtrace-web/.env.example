# Copy to .env.local — never commit .env.local to git

# Supabase (get from supabase.com → project settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API key (must match API_KEY in pawtrace-backend/.env)
VITE_BACKEND_API_KEY=your-api-key

# Backend URL (optional — defaults to http://127.0.0.1:5001)
VITE_BACKEND_URL=http://127.0.0.1:5001
